<Page
    x:Class="RetroBatGameModeWidget.WidgetPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="12" Background="#1F1F23">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>
            <Image Grid.Column="0" Width="36" Height="36" Source="ms-appx:///Assets/Square150x150Logo.png" Stretch="Uniform" />
            <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                <TextBlock Text="RetroBat Game Mode" FontWeight="SemiBold" Foreground="White" FontSize="16" />
                <TextBlock Text="v1.5" Foreground="#9AA0AA" FontSize="11" />
          </StackPanel>
      </Grid>

<Border Grid.Row="1" Background="#2A2A30" CornerRadius="4" Padding="10,8,10,8" Margin="0,0,0,8">
            <StackPanel>
                <TextBlock x:Name="StatusText"
                           Text="Disconnected"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Foreground="#F43F5E"
                           HorizontalAlignment="Center" />
                <TextBlock x:Name="TriggerText" Text="Idle"
                           FontSize="11" Foreground="#9AA0AA"
                           HorizontalAlignment="Center" Margin="0,2,0,0" />
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="2" VerticalAlignment="Center" Spacing="6">
            <Button x:Name="EnableToggleButton" Content="Enable" Click="EnableToggleButton_Click"
                    HorizontalAlignment="Stretch" Height="36" />
            <Button x:Name="StandaloneToggleButton" Content="Mode: Off"
                    Click="StandaloneToggleButton_Click"
                    HorizontalAlignment="Stretch" Height="36" />
            <Button x:Name="TargetButton" Content="Target" Click="TargetButton_Click" HorizontalAlignment="Stretch" Height="42" Margin="0,8,0,0" />
            <Button x:Name="AppsButton" Content="Apps" Click="AppsButton_Click"
                    HorizontalAlignment="Stretch" Height="36" Margin="0,8,0,0" />
            <Button x:Name="EmergencyButton" Content="⚠ Emergency Restore"
                    Click="EmergencyButton_Click"
                    HorizontalAlignment="Stretch" Height="32"
                    Foreground="White"
                    Background="#7F1D1D"
                    BorderBrush="#991B1B"
                    Margin="0,4,0,0"
                    FontSize="12"
                    ToolTipService.ToolTip="Panic restore: forces a full undo via HTTP if alive, or via config.ini EmergencyRestore=1 flag if backend HTTP is broken." />
     </StackPanel>

        <TextBlock Grid.Row="3" x:Name="FooterText" Text="Win+G to open the widget" Foreground="#6B7280" FontSize="11" HorizontalAlignment="Center" Margin="0,8,0,0" />
  </Grid>
</Page>
